{
  "name": "mydev-bychat-io",
  "version": "1.0.0",
  "description": "mydev.bychat.io - Electron desktop application",
  "main": "dist-main/main/index.js",
  "bin": {
    "mydev": "./dist-cli/cli/index.js"
  },
  "scripts": {
    "build:main": "tsc",
    "build:cli": "tsc --project cli/tsconfig.json",
    "dev": "npm run build:main && concurrently \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "start": "npm run build:main && vite build && electron .",
    "build": "npm run build:main && vite build && electron-builder",
    "build:mac": "npm run build:main && vite build && electron-builder --mac",
    "build:win": "npm run build:main && vite build && electron-builder --win",
    "build:linux": "npm run build:main && vite build && electron-builder --linux",
    "server": "tsx server/index.ts",
    "server:dev": "tsx watch server/index.ts",
    "cli": "tsx cli/index.ts"
  },
  "build": {
    "appId": "io.bychat.mydev",
    "productName": "mydev.bychat.io",
    "directories": {
      "output": "dist"
    },
    "files": [
      "dist-main/**/*",
      "preload.js",
      "debug-window.html",
      "renderer/dist/**/*"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^6.0.0",
    "wait-on": "^8.0.0"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "@xyflow/react": "^12.10.1",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "node-pty": "^1.1.0",
    "openai": "^6.22.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  }
}
