# ───────────────────────────────────────────────
#  flovia — Environment Variables
# ───────────────────────────────────────────────
#  Copy this to .env and fill in your values.
#  NEVER commit the real .env to version control.
# ───────────────────────────────────────────────

# ── App ──
VITE_DEV_SERVER=true          # Set to "true" to use Vite dev server in Electron

# ── Server (Enterprise Cloud) ──
PORT=3001                     # Port for the Express cloud server

# ── Data Directory (optional) ──
# FLOVIA_DATA_DIR=            # Override default data dir (shared by desktop/CLI/server)

# ── AI ──
OPENAI_API_KEY=               # OpenAI API key (or compatible provider)
OPENAI_BASE_URL=              # OpenAI-compatible API base URL (leave blank for default)
OLLAMA_BASE_URL=http://localhost:11434/v1  # Ollama local server URL
ANTHROPIC_API_KEY=            # Anthropic API key for Claude models (https://console.anthropic.com/settings/keys)
FLOVIA_MODEL=                 # Default model name (e.g. gpt-4o, llama3, claude-sonnet-4, etc.)

# ── GitHub ──
GITHUB_TOKEN=                 # GitHub Personal Access Token (repo + workflow scopes)
# GH_TOKEN=                   # Alternative GitHub token variable (fallback)

# ── Atlassian / Jira ──
# Primary method: configure via the UI (stored in atlassian-connections.json).
# Optional: set these env vars to auto-load a connection on startup.
ATLASSIAN_DOMAIN=             # e.g. mycompany.atlassian.net
ATLASSIAN_EMAIL=              # Atlassian account email
ATLASSIAN_API_TOKEN=          # Atlassian API token (https://id.atlassian.com/manage-profile/security/api-tokens)

# ── Supabase ──
# (Auto-detected from your workspace .env files containing supabase URLs.
#  No env vars needed here — flovia scans for SUPABASE_SERVICE_ROLE_KEY
#  and supabase.co URLs in your project.)
