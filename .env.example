# ───────────────────────────────────────────────
#  mydev.bychat.io — Environment Variables
# ───────────────────────────────────────────────
#  Copy this to .env and fill in your values.
#  NEVER commit the real .env to version control.
# ───────────────────────────────────────────────

# ── App ──
VITE_DEV_SERVER=true          # Set to "true" to use Vite dev server in Electron

# ── Server (Enterprise Cloud) ──
PORT=3001                     # Port for the Express cloud server

# ── GitHub ──
GITHUB_TOKEN=                 # GitHub Personal Access Token (repo + workflow scopes)

# ── AI ──
OPENAI_API_KEY=               # OpenAI API key (or compatible provider)
OLLAMA_BASE_URL=http://localhost:11434/v1  # Ollama local server URL
